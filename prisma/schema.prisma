generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  PREMIUM
}

// ─── NextAuth Tables ────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  plan          Plan      @default(FREE)
  stripeId      String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  analyses        ProfileAnalysis[]
  savedSuggestions SavedSuggestion[]

  @@map("users")
}

// ─── App Tables ─────────────────────────────────────────────

model ProfileAnalysis {
  id        String   @id @default(cuid())
  userId    String
  source    String   // "linkedin_url" | "pdf_upload"
  input     String   // URL ou nome do arquivo
  scores    Json     // { title, summary, experience, overall }
  feedback  Json     // { title, summary, experience, tips[] }
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("profile_analyses")
}

model SavedSuggestion {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "post_idea" | "about_rewrite" | "experience_rewrite"
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_suggestions")
}

model MarketAnalysis {
  id            String   @id @default(cuid())
  searchTag     String   // "front-end", "back-end", etc.
  totalScraped  Int      // Total de vagas encontradas na busca
  totalAnalyzed Int      // Total com descrição analisada
  skills        Json     // [{ skill, count, percentage }]
  createdAt     DateTime @default(now())

  @@index([searchTag, createdAt(sort: Desc)])
  @@map("market_analyses")
}
